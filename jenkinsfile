pipeline {
	agent any
	environment {
		JAVA_HOME = '/usr/lib/jvm/java-21-amazon-corretto.x86_64'
		PATH ="${JAVA_HOME}/bin:/usr/local/bin:/usr/bin:/bin"
		}

	stages {
		stage('compile'){
			steps {
				sh 'mvn clean compile'
				}
			}
		stage('test') {
			steps{
				sh 'mvn test'
		}
	}
	stage('package'){
	steps {
	sh 'mvn package'
	}
	}
	stage ('archive') {
	steps {
		archiveArtifacts artifacts:'target/*.jar'
			}
		}
	}
}
